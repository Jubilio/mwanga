# Database — NUNCA commitar ficheiros .db (podem conter dados reais de utilizadores)
# Se server/*.db já foi commitado, executar:
#   git rm --cached server/*.db
#   git commit -m "chore: remove db files from tracking"
server/*.db
server/*.db-journal
server/*.db-shm
server/*.db-wal
*.sqlite
*.sqlite3

