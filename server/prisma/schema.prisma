generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Household {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  users              User[]
  transactions       Transaction[]
  budgets            Budget[]
  goals              Goal[]
  rentals            Rental[]
  assets             Asset[]
  liabilities        Liability[]
  xitiques           Xitique[]
  credits            Credit[]
  debts              Debt[]
  notifications      Notification[]
  smsImports         SmsImport[]
  pushSubscriptions  PushSubscription[]
  behaviorEvents     BehaviorEvent[]
}

model User {
  id                 Int      @id @default(autoincrement())
  name               String
  email              String   @unique
  passwordHash       String
  householdId        Int
  household          Household @relation(fields: [householdId], references: [id])
  nationalId         String?
  kycStatus          String   @default("pending")
  creditScore        Int      @default(0)
  role               String   @default("user")
  createdAt          DateTime @default(now())
  notifications      Notification[]
  smsImports         SmsImport[]
  pushSubscriptions  PushSubscription[]
  behaviorEvents     BehaviorEvent[]
}

model Transaction {
  id                Int      @id @default(autoincrement())
  date              String
  type              String
  description       String?
  amount            Float
  category          String?
  note              String?
  sourceType        String   @default("manual")
  externalReference String?
  feeAmount         Float    @default(0)
  confidenceScore   Float?
  householdId       Int
  household         Household @relation(fields: [householdId], references: [id])
  createdAt         DateTime @default(now())
}

model Budget {
  id          Int      @id @default(autoincrement())
  category    String
  limitAmount Float
  householdId Int
  household   Household @relation(fields: [householdId], references: [id])
  @@unique([category, householdId])
}

model Goal {
  id            Int      @id @default(autoincrement())
  name          String
  targetAmount  Float
  savedAmount   Float    @default(0)
  deadline      String?
  category      String?
  monthlySaving Float    @default(0)
  householdId   Int
  household     Household @relation(fields: [householdId], references: [id])
  createdAt     DateTime @default(now())
}

model Rental {
  id          Int      @id @default(autoincrement())
  month       String
  landlord    String
  amount      Float
  status      String
  notes       String?
  householdId Int
  household   Household @relation(fields: [householdId], references: [id])
  createdAt   DateTime @default(now())
}

model Asset {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  value       Float
  householdId Int
  household   Household @relation(fields: [householdId], references: [id])
  createdAt   DateTime @default(now())
}

model Liability {
  id              Int      @id @default(autoincrement())
  name            String
  totalAmount     Float
  remainingAmount Float
  interestRate    Float    @default(0)
  householdId     Int
  household       Household @relation(fields: [householdId], references: [id])
  createdAt       DateTime @default(now())
}

model Xitique {
  id             Int      @id @default(autoincrement())
  name           String
  monthlyAmount  Float
  householdId    Int
  household      Household @relation(fields: [householdId], references: [id])
  createdAt      DateTime @default(now())
}

model Credit {
  id          Int      @id @default(autoincrement())
  type        String
  amount      Float
  interestRate Float
  termMonths  Int
  householdId Int
  household   Household @relation(fields: [householdId], references: [id])
  createdAt   DateTime @default(now())
}

model Debt {
  id          Int      @id @default(autoincrement())
  name        String
  amount      Float
  householdId Int
  household   Household @relation(fields: [householdId], references: [id])
  createdAt   DateTime @default(now())
}

model Notification {
  id            Int       @id @default(autoincrement())
  type          String
  title         String?
  message       String
  channel       String    @default("in_app")
  tone          String    @default("friendly")
  actionPayload Json?
  metadata      Json?
  dedupeKey     String?
  status        String    @default("stored")
  read          Boolean   @default(false)
  sentAt        DateTime?
  deliveredAt   DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  userId        Int?
  user          User?     @relation(fields: [userId], references: [id])
  householdId   Int
  household     Household @relation(fields: [householdId], references: [id])
  createdAt     DateTime  @default(now())

  @@index([userId, createdAt])
  @@unique([userId, dedupeKey])
}

model SmsImport {
  id          Int      @id @default(autoincrement())
  content     String
  parsedData  String?
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  householdId Int
  household   Household @relation(fields: [householdId], references: [id])
  createdAt   DateTime @default(now())
}

model PushSubscription {
  id             Int       @id @default(autoincrement())
  householdId    Int
  household      Household @relation(fields: [householdId], references: [id])
  userId         Int
  user           User      @relation(fields: [userId], references: [id])
  endpoint       String    @unique
  p256dhKey      String
  authKey        String
  expirationTime String?
  deviceType     String    @default("pwa")
  platform       String    @default("web")
  userAgent      String?
  isActive       Boolean   @default(true)
  failureCount   Int       @default(0)
  lastError      String?
  lastSeenAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())

  @@index([userId, isActive])
}

model BehaviorEvent {
  id          Int       @id @default(autoincrement())
  householdId Int
  household   Household @relation(fields: [householdId], references: [id])
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id])
  eventName   String
  eventSource String
  eventValue  Float?
  context     Json?
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
}
